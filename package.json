{
  "name": "claude-code-focus",
  "displayName": "Claude Code Focus",
  "description": "Auto-control terminal panel based on Claude Code status",
  "version": "0.0.3",
  "publisher": "HayaShin5",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HayaShin5/claude-code-focus"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "terminal",
    "automation"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-code-focus.setupHooks",
        "title": "Claude Code Focus: Setup Hooks"
      }
    ],
    "configuration": {
      "title": "Claude Code Focus",
      "properties": {
        "claude-code-focus.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable automatic terminal panel control."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
