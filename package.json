{
  "name": "claude-code-ninja",
  "displayName": "ClaudeCodeNinja",
  "description": "Claude Code works silently in the background. You don't need to watch.",
  "version": "0.0.9",
  "icon": "assets/icon.png",
  "publisher": "HayaShin5",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HayaShin5/claude-code-ninja"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "terminal",
    "automation"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-code-ninja.setupHooks",
        "title": "ClaudeCodeNinja: Setup Hooks"
      }
    ],
    "configuration": {
      "title": "ClaudeCodeNinja",
      "properties": {
        "claude-code-ninja.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable automatic terminal panel control."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
